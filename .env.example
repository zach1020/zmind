# ZMind Environment Variables
# Copy this file to .env.local and fill in your values

# API key used to protect all API routes (pick any strong random string)
ZMIND_API_KEY=your-secret-api-key-here
NEXT_PUBLIC_ZMIND_API_KEY=your-secret-api-key-here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic (Claude) — powers AI chat and auto-tagging
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App URL (used by the Chrome extension)
NEXT_PUBLIC_APP_URL=http://localhost:3000
